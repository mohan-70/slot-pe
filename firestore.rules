rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwnerOf(businessId) {
      return isAuthenticated() && 
             exists(/databases/(default)/documents/businesses/$(businessId)) &&
             get(/databases/(default)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }
    
    function isBusinessOwner(userId) {
      return request.auth.uid == userId;
    }

    // Businesses collection
    match /businesses/{businessId} {
      // Allow anyone to read public business info
      allow read: if true;
      
      // Allow authenticated users to create a business
      allow create: if isAuthenticated() && 
                       request.resource.data.ownerId == request.auth.uid &&
                       request.resource.data.name is string &&
                       request.resource.data.category is string &&
                       request.resource.data.city is string &&
                       request.resource.data.bookingSlug is string &&
                       request.resource.data.workingDays is list &&
                       request.resource.data.openTime is string &&
                       request.resource.data.closeTime is string;
      
      // Allow only the business owner to update/delete their business
      allow update, delete: if isOwnerOf(businessId);

      // Services subcollection
      match /services/{serviceId} {
        // Allow anyone to read services
        allow read: if true;
        
        // Allow only business owner to manage services
        allow create, update, delete: if isOwnerOf(businessId) &&
                                         (
                                           request.resource.data.name is string &&
                                           request.resource.data.duration is number &&
                                           request.resource.data.price is number
                                         );
      }

      // Availability/TimeSlots subcollection
      match /timeSlots/{date} {
        // Allow anyone to read time slots
        allow read: if true;
        
        // Allow only business owner to manage time slots
        allow create, update, delete: if isOwnerOf(businessId) &&
                                         request.resource.data.slots is map;
      }

      // Reviews subcollection
      match /reviews/{reviewId} {
        // Allow anyone to read public reviews
        allow read: if true;
        
        // Allow authenticated users to create reviews
        allow create: if isAuthenticated() &&
                        request.resource.data.customerId == request.auth.uid &&
                        request.resource.data.rating is number &&
                        request.resource.data.rating >= 1 &&
                        request.resource.data.rating <= 5 &&
                        request.resource.data.comment is string;
        
        // Allow review author or business owner to update/delete reviews
        allow update, delete: if (resource.data.customerId == request.auth.uid ||
                                  isOwnerOf(businessId));
      }
    }

    // Bookings collection
    match /bookings/{bookingId} {
      // Allow authenticated users to read their own bookings
      allow read: if isAuthenticated() && 
                     (request.auth.uid == resource.data.customerId ||
                      isOwnerOf(resource.data.businessId));
      
      // Allow authenticated users to create bookings
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.customerId &&
                       request.resource.data.businessId is string &&
                       request.resource.data.serviceId is string &&
                       request.resource.data.serviceName is string &&
                       request.resource.data.date is string &&
                       request.resource.data.timeSlot is string &&
                       request.resource.data.status == 'pending' &&
                       request.resource.data.customerPhone is string;
      
      // Allow business owner to update booking status
      allow update: if isOwnerOf(resource.data.businessId) && 
                       request.resource.data.status in ['confirmed', 'cancelled', 'completed', 'no-show'];
      
      // Allow customer to update/cancel their own booking (before confirmation)
      allow update, delete: if request.auth.uid == resource.data.customerId &&
                               resource.data.status == 'pending';
    }

    // Users collection (for user profiles)
    match /users/{userId} {
      // Allow users to read their own profile
      allow read: if request.auth.uid == userId;
      
      // Allow authenticated users to create their profile
      allow create: if request.auth.uid == userId &&
                       request.resource.data.email is string &&
                       request.resource.data.displayName is string;
      
      // Allow users to update their own profile
      allow update: if request.auth.uid == userId;
      
      // Prevent deletion (optional)
      allow delete: if false;
    }

    // Activity Log collection (optional for auditing)
    match /activityLog/{logId} {
      // Allow only backend/service accounts to write
      allow create: if request.auth != null;
      
      // Allow only the relevant user to read their logs
      allow read: if request.auth.uid == resource.data.userId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
